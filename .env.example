# ============================================================
# JoJobs — Environment template (safe to commit)
# ============================================================
# Local setup:
#   cp .env.example .env.local
#   Fill secrets in .env.local only — never commit .env.local
#
# Production (Vercel Dashboard only — not in Git):
#   Same keys, production values — see docs/DEPLOYMENT.md

# ── Database (Supabase Pooler + direct for migrations) ─────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# ── Site ────────────────────────────────────────────────────
# Local dev:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production (Vercel only):
# NEXT_PUBLIC_SITE_URL="https://www.jordan-job.shop"

NEXT_PUBLIC_SITE_NAME="وظائف الأردن"
NEXT_PUBLIC_APP_NAME="JoJobs"
NEXT_PUBLIC_APP_NAME_AR="جوبز الأردن"

# ── Contact (public labels + server routing) ────────────────
NEXT_PUBLIC_CONTACT_EMAIL="info@jordan-job.shop"
NEXT_PUBLIC_SUPPORT_EMAIL="info@jordan-job.shop"
NEXT_PUBLIC_COMPANY_EMAIL="info@jordan-job.shop"
SUPPORT_EMAIL="info@jordan-job.shop"
CONTACT_TO_EMAIL="info@jordan-job.shop"
COMPANY_EMAIL="info@jordan-job.shop"

# ── SMTP (Hostinger) — required for OTP & email ─────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="info@jordan-job.shop"
SMTP_PASS="change_me"
SMTP_FROM="JoJobs <info@jordan-job.shop>"

# Optional: Resend (if set, takes priority over SMTP)
# RESEND_API_KEY=""
# RESEND_FROM="JoJobs <info@jordan-job.shop>"

# ── Auth (min 32 characters) ────────────────────────────────
SESSION_PASSWORD="your-secret-key-at-least-32-characters-long"
SESSION_SECRET="your-secret-key-at-least-32-characters-long"
ADMIN_EMAILS="info@jordan-job.shop"

# Optional: scripts/bootstrap-admin.ts
# ADMIN_BOOTSTRAP_PASSWORD=""

# ── Features ────────────────────────────────────────────────
DEV_MODE="false"
ALLOW_FREE_CV_PDF="false"
REQUIRE_CV_PAYMENT="true"
ENABLE_EXTERNAL_JOB_SOURCES="false"
DEFAULT_CITY="عمان"

# ── WhatsApp ────────────────────────────────────────────────
SUPPORT_WHATSAPP="962790565018"
PLATFORM_WHATSAPP="962790565018"
NEXT_PUBLIC_WHATSAPP_NUMBER="962790565018"
NEXT_PUBLIC_WHATSAPP_URL="https://wa.me/962790565018"

# ── Cron (Vercel scheduled jobs — use strong secret in prod) ─
CRON_SECRET="generate-a-strong-secret-here"

# ── SEO / Analytics (optional) ──────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ── Optional: AI CV English translation ─────────────────────
# Official Anthropic:
# ANTHROPIC_API_KEY=""
#
# Anthropic-compatible proxy:
# ANTHROPIC_BASE_URL="https://api.synterolink.com"
# ANTHROPIC_AUTH_TOKEN=""
