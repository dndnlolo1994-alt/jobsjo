# JoJobs OS - environment variables
# انسخ هذا الملف إلى .env واملأ القيم

# قاعدة البيانات: PostgreSQL في الإنتاج، SQLite في التطوير المحلي
DATABASE_URL="postgresql://user:password@localhost:5432/jojobs?schema=public"

# عنوان الموقع العام (يُستخدم في metadataBase، sitemap، OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# اسم الموقع الظاهر للمستخدم
NEXT_PUBLIC_SITE_NAME="جوبز الأردن"

# سر جلسات iron-session — يجب أن يكون 32 حرف على الأقل
SESSION_PASSWORD="please-change-me-32-characters-min-secret"
SESSION_SECRET="please-change-me-32-characters-min-secret"

# قائمة إيميلات الأدمن مفصولة بفواصل
ADMIN_EMAILS="admin@example.com"

# تفعيل وضع التطوير لميزات معينة (مثل تعليم الدفع كمدفوع تلقائياً)
DEV_MODE="true"

# تفعيل/تعطيل تنزيل PDF بدون دفع (للديمو)
ALLOW_FREE_CV_PDF="false"

# واتساب رقم الدعم (يبدأ بـ 962، بدون + أو 00)
SUPPORT_WHATSAPP="962790000000"
PLATFORM_WHATSAPP="962790000000"
SUPPORT_EMAIL="support@example.com"
REQUIRE_CV_PAYMENT="true"
ENABLE_EXTERNAL_JOB_SOURCES="false"
DEFAULT_CITY="إربد"
