{
  "name": "jojobs-os",
  "version": "0.1.0",
  "private": true,
  "description": "JoJobs OS — جوبز الأردن: منصة وظائف الأردن مع باني السيرة الذاتية وتتبع الطلبات",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy || echo '[WARN] prisma migrate deploy did not complete — continuing build; verify DB schema/migrations manually'; next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js validate",
    "prisma:generate": "node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js migrate dev",
    "prisma:push": "node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js db push",
    "seed": "node -r ./scripts/load-env.cjs ./node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "test": "node -r ./scripts/load-env.cjs ./node_modules/tsx/dist/cli.mjs tests/run.ts",
    "test:email": "node -r ./scripts/load-env.cjs ./node_modules/tsx/dist/cli.mjs scripts/send-test-email.ts",
    "cv:mockup": "node scripts/capture-cv-mockup.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.17.0",
    "next": "^15.5.18",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.4",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.0.3",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
